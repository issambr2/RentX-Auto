{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "Represents a rental vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "plate": { "type": "string" },
        "washStatus": { "type": "string", "enum": ["clean", "dirty"], "description": "Default is clean" },
        "lastWashDate": { "type": "string", "format": "date-time" }
      },
      "required": ["brand", "model", "plate"]
    }
  },
  "firestore": {
    "/vehicles": {
      "schema": "Vehicle",
      "description": "Collection of rental vehicles"
    }
  }
}
